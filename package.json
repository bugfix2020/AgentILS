{
    "name": "agentils-workspace",
    "private": true,
    "packageManager": "pnpm@10.14.0",
    "scripts": {
        "agentils:install:vscode": "pnpm --filter @agent-ils/cli build && node packages/cli/dist/index.js install vscode --workspace apps/vscode-debug",
        "agentils:uninstall:vscode": "pnpm --filter @agent-ils/cli build && node packages/cli/dist/index.js uninstall vscode --workspace apps/vscode-debug",
        "build": "turbo run build",
        "dev": "turbo run dev --parallel",
        "dev:http": "pnpm --filter @agent-ils/mcp dev:http",
        "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
        "changelog:all": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
        "generate:flowcharts": "node scripts/flowcharts/generate-all.mjs",
        "generate:changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
        "generate:changelog:first": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
        "sync:instructions": "node scripts/dev/sync-agent-instructions.mjs",
        "sync:instructions:check": "node scripts/dev/sync-agent-instructions.mjs --check",
        "smoke": "pnpm --filter @agent-ils/mcp smoke",
        "start": "pnpm --filter @agent-ils/mcp start",
        "start:http": "pnpm --filter @agent-ils/mcp start:http",
        "start:webview": "pnpm --filter agentils-vscode-webview start",
        "test": "turbo run test",
        "test:unit": "pnpm --filter @agent-ils/mcp test",
        "typecheck": "turbo run typecheck",
        "typecheck:vscode-host": "pnpm --filter agentils-vscode typecheck",
        "verify:surfaces": "pnpm --filter agentils-vscode typecheck",
        "prepare": "husky",
        "commit": "git-cz",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@eslint/js": "^9.25.0",
        "commitizen": "^4.3.1",
        "conventional-changelog-cli": "^5.0.0",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.25.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.5.3",
        "puppeteer-core": "^24.42.0",
        "terminalizer": "^0.12.0",
        "turbo": "^2.9.6",
        "typescript-eslint": "^8.31.0"
    }
}
