{
  "name": "agentils-workspace",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "agentils:inject:vscode": "pnpm --filter @agentils/cli build && node packages/cli/dist/index.js inject vscode --workspace .",
    "agentils:uninstall:vscode": "pnpm --filter @agentils/cli build && node packages/cli/dist/index.js uninstall vscode --workspace .",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:http": "pnpm --filter @agentils/mcp dev:http",
    "generate:flowcharts": "node scripts/flowcharts/generate-all.mjs",
    "sync:instructions": "node scripts/sync-agent-instructions.mjs",
    "sync:instructions:check": "node scripts/sync-agent-instructions.mjs --check",
    "smoke": "pnpm --filter @agentils/mcp smoke",
    "start": "pnpm --filter @agentils/mcp start",
    "start:http": "pnpm --filter @agentils/mcp start:http",
    "test": "turbo run test",
    "test:unit": "pnpm --filter @agentils/mcp test",
    "typecheck": "turbo run typecheck",
    "typecheck:vscode-host": "pnpm --filter agentils-vscode typecheck",
    "verify:surfaces": "pnpm --filter agentils-vscode typecheck"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
