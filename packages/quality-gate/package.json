{
    "name": "@agent-ils/quality-gate",
    "version": "0.0.1",
    "description": "Initialize Husky, lint-staged, Prettier, commitlint, and Conventional Commits defaults for a project.",
    "keywords": [
        "agentils",
        "quality-gate",
        "precommit",
        "husky",
        "lint-staged",
        "prettier",
        "commitlint",
        "conventional-commits",
        "ecam",
        "tui"
    ],
    "homepage": "https://github.com/bugfix2020/AgentILS/tree/main/packages/quality-gate#readme",
    "bugs": {
        "url": "https://github.com/bugfix2020/AgentILS/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bugfix2020/AgentILS.git",
        "directory": "packages/quality-gate"
    },
    "license": "MIT",
    "author": "AgentILS contributors (https://github.com/bugfix2020/AgentILS)",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "agentils-quality-gate": "dist/cli.js",
        "agentils-precommit-gate": "dist/precommit.js"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist",
        "README.md",
        "README.zh-CN.md"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsup && node scripts/copy-templates.mjs",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@clack/prompts": "^0.11.0",
        "cac": "^6.7.14",
        "ink": "^5.2.1",
        "react": "^18.3.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "@types/react": "^18.3.12",
        "tsup": "^8.5.1",
        "typescript": "^5.8.3"
    }
}
