{
    "name": "@agent-ils/workflow-sdk",
    "version": "0.0.3",
    "description": "Framework-agnostic workflow infrastructure for AgentILS",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js"
        },
        "./vue": {
            "types": "./dist/vue.d.ts",
            "import": "./dist/vue.js"
        }
    },
    "files": [
        "dist/**/*.js",
        "dist/**/*.d.ts",
        "!dist/**/*.map"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bugfix2020/AgentILS",
        "directory": "packages/workflow-sdk"
    },
    "license": "MIT",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "tsx --test __tests__/**/*.test.ts",
        "test:core": "tsx --test src/core/__tests__/**/*.test.ts",
        "test:react": "tsx --test src/react/__tests__/**/*.test.ts",
        "test:vue": "tsx --test src/vue/__tests__/**/*.test.ts"
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.2",
        "@types/node": "^22.15.3",
        "@types/react": "^18.3.12",
        "tsup": "^8.5.1",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "vue": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "vue": {
            "optional": true
        }
    }
}
