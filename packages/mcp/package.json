{
    "name": "@agent-ils/mcp",
    "version": "0.1.0",
    "description": "AgentILS core MCP server (stdio + HTTP dual transport, persisted state machine)",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "agentils-mcp": "./dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./client": {
            "types": "./dist/client/index.d.ts",
            "import": "./dist/client/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "start:http": "node dist/index.js --http",
        "start:stdio": "node dist/index.js --stdio",
        "typecheck": "tsc --noEmit",
        "test": "tsx --test test/**/*.test.ts"
    },
    "dependencies": {
        "@agent-ils/logger": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "express": "^5.1.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^22.15.3",
        "tsup": "^8.5.1",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}
