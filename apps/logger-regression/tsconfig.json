{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "dist",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "types": ["node", "vite/client"],
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"]
}
