#!/usr/bin/env sh
# Pre-push gate: refuse the push if CHANGELOG.md is stale relative to current HEAD.
# Authoritative rule: docs/instructions/agentils.instructions.md → "发布前 Changelog 同步".

set -eu

if [ ! -f CHANGELOG.md ]; then
  echo "[pre-push] CHANGELOG.md missing — run: pnpm changelog:all && git add CHANGELOG.md && git commit"
  exit 1
fi

# If HEAD itself is a "chore(changelog)" commit, the changelog cannot include
# its own hash without an infinite loop. Accept it as already-up-to-date.
HEAD_SUBJECT="$(git log -1 --pretty=%s)"
case "$HEAD_SUBJECT" in
  "chore(changelog)"*)
    echo "[pre-push] ✓ HEAD is chore(changelog) — skipping drift check"
    exit 0
    ;;
esac

TMP_BEFORE="$(mktemp)"
cp CHANGELOG.md "$TMP_BEFORE"

# Full regenerate (-r 0) since the repo has no release tags yet.
pnpm exec conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0 >/dev/null

if diff -q "$TMP_BEFORE" CHANGELOG.md >/dev/null; then
  rm -f "$TMP_BEFORE"
  echo "[pre-push] ✓ CHANGELOG.md is up to date"
  exit 0
fi

# Drift detected — auto-commit the regenerated CHANGELOG. The new commit is NOT
# part of the in-flight push (git already captured the refs to push before this
# hook ran), so we abort to force a clean re-push that carries the sync commit.
# The next pre-push run will see HEAD = chore(changelog) and skip the check
# (case branch above), preventing infinite loops.
rm -f "$TMP_BEFORE"
echo "[pre-push] ✱ CHANGELOG.md was stale"
git add CHANGELOG.md
git -c core.hooksPath=/dev/null commit -m "chore(changelog): sync" >/dev/null
echo "[pre-push] ✓ auto-committed 'chore(changelog): sync' on top of HEAD"
echo "[pre-push] ✗ aborting this push — please run 'git push' again to include the sync commit"
exit 1
