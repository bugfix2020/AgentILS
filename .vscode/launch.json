{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AgentILS: VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extensions/agentils-vscode",
        "--folder-uri=file://${workspaceFolder}/apps/vscode-debug"
      ],
      "env": {
        "AGENTILS_DEBUG": "true"
      },
      "preLaunchTask": "prepare:agentils-extensions",
      "outFiles": [
        "${workspaceFolder}/packages/extensions/agentils-vscode/dist/**/*.js",
        "${workspaceFolder}/packages/extensions/agentils-vscode/dist/**/*.cjs"
      ]
    }
  ]
}
