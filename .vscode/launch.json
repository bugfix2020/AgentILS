{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AgentILS: VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/agentils-vscode"
      ],
      "preLaunchTask": "prepare:agentils-extensions",
      "outFiles": [
        "${workspaceFolder}/extensions/agentils-vscode/dist/**/*.js"
      ]
    },
    {
      "name": "AgentILS: UI Helper Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/agentils-ui-helper"
      ],
      "preLaunchTask": "prepare:agentils-extensions"
    },
    {
      "name": "AgentILS: Both Extensions",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/agentils-vscode",
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/agentils-ui-helper"
      ],
      "preLaunchTask": "prepare:agentils-extensions",
      "outFiles": [
        "${workspaceFolder}/extensions/agentils-vscode/dist/**/*.js"
      ]
    }
  ]
}
