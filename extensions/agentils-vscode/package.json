{
    "name": "agentils-vscode",
    "displayName": "AgentILS",
    "description": "AgentILS V1 persistent WebView loop for VS Code",
    "version": "1.0.0",
    "publisher": "bugfix2020",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other",
        "AI"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "agentils.installPromptPack",
                "title": "AgentILS: Install Prompt Pack"
            },
            {
                "command": "agentils.openPanel",
                "title": "AgentILS: Open Panel"
            }
        ],
        "languageModelTools": [
            {
                "name": "agentils_run_task_loop",
                "displayName": "Run Task Loop",
                "modelDescription": "The only AgentILS V1 loop entry. Read state first, then drive the persistent WebView-backed MCP task loop.",
                "userDescription": "Start or resume the AgentILS V1 task loop.",
                "toolReferenceName": "runTaskLoop",
                "description": "The only AgentILS V1 loop entry. Opens the persistent WebView and drives the MCP loop.",
                "canBeReferencedInPrompt": true,
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "userIntent": {
                            "type": "string",
                            "description": "The current user request"
                        },
                        "taskId": {
                            "type": "string"
                        },
                        "sessionId": {
                            "type": "string"
                        },
                        "directive": {
                            "type": "string",
                            "enum": [
                                "noop",
                                "draft_plan",
                                "request_clarification",
                                "execute",
                                "execution_succeeded",
                                "execution_failed",
                                "tests_passed",
                                "tests_failed",
                                "finish"
                            ]
                        }
                    }
                },
                "tags": [
                    "agentils",
                    "loop",
                    "entry-point"
                ]
            },
            {
                "name": "agentils_state_get",
                "displayName": "State Get",
                "modelDescription": "Read the current AgentILS V1 state before calling the loop tool.",
                "userDescription": "Read the current AgentILS V1 task and session state.",
                "toolReferenceName": "stateGet",
                "description": "Read the current AgentILS V1 state before calling the loop tool.",
                "canBeReferencedInPrompt": true,
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "taskId": {
                            "type": "string"
                        }
                    }
                },
                "tags": [
                    "agentils",
                    "state"
                ]
            }
        ],
        "configuration": {
            "title": "AgentILS",
            "properties": {
                "agentils.runtime.serverModulePath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional absolute path to the built AgentILS MCP server entrypoint."
                }
            }
        }
    },
    "scripts": {
        "build": "npm --prefix ./webview run build && tsc -p .",
        "watch": "tsc -p . -w",
        "typecheck": "npm --prefix ./webview run typecheck && tsc -p . --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.3",
        "@types/vscode": "^1.90.0",
        "typescript": "^5.8.3"
    }
}
